# =============================================================================
# TradingAlgoWork — production / local env contract
# Copy to .env (repo root) and never commit secrets.
# =============================================================================

# --- Market data (backend) ---------------------------------------------------
# LSE streaming + vault key. Required for production live market data.
LSE_API_KEY=lse_live_your_key_here

# --- Python market-runtime service (Render / Cloud Run / local) --------------
# Host/port when running: uvicorn services.market_runtime.server:app --host 0.0.0.0 --port 8000
PORT=8000
# Use production in every deployed backend. Production refuses to start without
# MARKET_RUNTIME_API_TOKEN and defaults stream-dependent plans to fail closed.
MARKET_RUNTIME_ENV=development
# Required in production. Set the identical secret on the Python backend and
# Trade Desk frontend; never expose it through NEXT_PUBLIC_* variables.
# MARKET_RUNTIME_API_TOKEN=replace-with-a-long-random-secret
# Override stream policy only deliberately (production default is fail closed).
# MARKET_RUNTIME_REQUIRE_STREAM=0
# MARKET_RUNTIME_MAX_SYMBOLS=1000

# --- Trade Desk frontend (Next.js / Vercel) ----------------------------------
# Set this so FE API routes call the remote backend instead of spawning Python.
# Production: https://your-market-runtime.onrender.com  (no trailing slash)
# Local:      http://127.0.0.1:8000
MARKET_RUNTIME_URL=http://127.0.0.1:8000

# Optional: local Python for monorepo-dev spawn fallback (unset in pure FE deploy)
# PYTHON_BIN=/path/to/.venv/bin/python
