//@version=6
// MODEL: poc_va_macdha v2_vwap
// Stack: prior VP (POC/VA 70%) + St.MACD HA + Dynamic Swing Anchored VWAP (Zeiierman-style)
// + volume expansion gate. Mirror of models/poc_va_macdha/v2_vwap/signal_engine.py
// Swing VWAP adaptation inspired by © Zeiierman Dynamic Swing Anchored VWAP (CC BY-NC-SA 4.0)

indicator("poc_va_macdha v2_vwap", overlay=true, max_bars_back=5000, max_labels_count=500, max_polylines_count=100)

// ── VP ──
vaPct     = input.float(70.0, "Value Area %", minval=1, maxval=100, group="Volume Profile") / 100.0
rows      = input.int(25, "Profile Rows", minval=10, maxval=100, group="Volume Profile")
lookback  = input.int(20, "Profile Lookback Bars", minval=1, group="Volume Profile")

// ── St.MACD HA ──
fastL     = input.int(12, "MACD Fast", group="St.MACD HA")
slowL     = input.int(26, "MACD Slow", group="St.MACD HA")
sigL      = input.int(9, "MACD Signal", group="St.MACD HA")
requireHA = input.bool(true, "Require HA green", group="St.MACD HA")

// ── Swing VWAP (Zeiierman-style) ──
prd       = input.int(50, "Swing Period", minval=2, group="Swing VWAP")
baseAPT   = input.float(20, "Adaptive Price Tracking", minval=1, group="Swing VWAP")
useAdapt  = input.bool(false, "Adapt APT by ATR ratio", group="Swing VWAP")
volBias   = input.float(10.0, "Volatility Bias", minval=0.1, group="Swing VWAP")
reqUp     = input.bool(true, "Require VWAP uptrend (dir>0)", group="Confidence")
reqAbove  = input.bool(true, "Require close >= VWAP", group="Confidence")
reqVol    = input.bool(true, "Require volume >= SMA", group="Confidence")
volLen    = input.int(20, "Volume SMA Length", group="Confidence")
colUp     = input.color(color.lime, "VWAP Up", group="Style")
colDn     = input.color(color.red, "VWAP Down", group="Style")

f_ema(src, len) => ta.ema(src, len)

f_st_macd_ha() =>
    hl = high - low
    macd = (f_ema(close, fastL) - f_ema(close, slowL)) / f_ema(hl, slowL) * 100.0
    o = nz(macd[1], macd)
    h = math.max(macd, o)
    l = math.min(macd, o)
    c = macd
    var float haO = na
    haC = (o + h + l + c) / 4.0
    haO := na(haO[1]) ? (o + c) / 2.0 : (haO[1] + haC[1]) / 2.0
    [haC > haO, haC, haO]

f_vp_levels() =>
    float hi = ta.highest(high, lookback)
    float lo = ta.lowest(low, lookback)
    float step = (hi - lo) / rows
    float poc = lo + (hi - lo) * 0.5
    float vah = hi
    float val = lo
    if step > 0
        array<float> bins = array.new_float(rows, 0.0)
        for i = 1 to lookback
            bh = high[i]
            bl = low[i]
            bv = volume[i]
            br = bh - bl
            for k = 0 to rows - 1
                binLo = lo + k * step
                binHi = binLo + step
                if bh >= binLo and bl < binHi
                    w = br == 0 ? 1.0 : step / br
                    array.set(bins, k, array.get(bins, k) + bv * w)
        float mx = array.max(bins)
        int pocIdx = array.indexof(bins, mx)
        float target = array.sum(bins) * vaPct
        float acc = array.get(bins, pocIdx)
        int above = pocIdx
        int below = pocIdx
        while acc < target
            if below == 0 and above == rows - 1
                break
            float va = above < rows - 1 ? array.get(bins, above + 1) : 0.0
            float vb = below > 0 ? array.get(bins, below - 1) : 0.0
            if va == 0 and vb == 0
                break
            if va >= vb
                above += 1
                acc += va
            else
                below -= 1
                acc += vb
        poc := lo + (pocIdx + 0.5) * step
        vah := lo + (above + 1.0) * step
        val := lo + below * step
    [poc, vah, val]

// ── Dynamic Swing Anchored VWAP (Zeiierman core) ──
var float ph = na
var float pl = na
var int phL = bar_index
var int plL = bar_index
var float p = na
var float vol = na
var float vap = na

ph  := ta.highestbars(high, prd) == 0 ? high : ph
pl  := ta.lowestbars(low, prd) == 0 ? low : pl
phL := ta.highestbars(high, prd) == 0 ? bar_index : phL
plL := ta.lowestbars(low, prd) == 0 ? bar_index : plL
dir = phL > plL ? 1 : -1

atrLen = 50
atr = ta.atr(atrLen)
atrAvg = ta.rma(atr, atrLen)
ratio = atrAvg > 0 ? atr / atrAvg : 1.0
aptRaw = useAdapt ? baseAPT / math.pow(ratio, volBias) : baseAPT
aptClamped = math.max(5.0, math.min(300.0, aptRaw))
aptSeries = math.round(aptClamped)
alphaFromAPT(apt) =>
    decay = math.exp(-math.log(2.0) / math.max(1.0, apt))
    1.0 - decay

if dir != dir[1]
    x = dir > 0 ? plL : phL
    y = dir > 0 ? pl : ph
    barsback = bar_index - x
    p := y * volume[barsback]
    vol := volume[barsback]
    for i = barsback to 0 by 1
        alpha = alphaFromAPT(aptSeries[i])
        pxv = hlc3[i] * volume[i]
        p := (1.0 - alpha) * p + alpha * pxv
        vol := (1.0 - alpha) * vol + alpha * volume[i]
    vap := vol > 0 ? p / vol : na
else
    alpha = alphaFromAPT(aptSeries)
    p := (1.0 - alpha) * nz(p, hlc3 * volume) + alpha * hlc3 * volume
    vol := (1.0 - alpha) * nz(vol, volume) + alpha * volume
    vap := vol > 0 ? p / vol : na

[poc, vah, val] = f_vp_levels()
[haGreen, haC, haO] = f_st_macd_ha()

volOk = volume >= ta.sma(volume, volLen)
uptrend = dir > 0
aboveVwap = close >= vap
pocOk = close >= poc
inVA = close >= val and close <= vah

longCond = pocOk and inVA and (not requireHA or haGreen) and (not reqUp or uptrend) and (not reqAbove or aboveVwap) and (not reqVol or volOk)

plot(poc, "POC", color=color.red, linewidth=2)
plot(vah, "VAH", color=color.blue)
plot(val, "VAL", color=color.blue)
plot(vap, "Swing VWAP", color=dir > 0 ? colUp : colDn, linewidth=2)
bgcolor(longCond ? color.new(color.green, 88) : na)
plotshape(longCond and not longCond[1], title="Long", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.tiny)
alertcondition(longCond and not longCond[1], "poc_va_macdha v2 long", "v2 VWAP-confirmed long setup")
