{
  "description": "Promotion gates for any model version claiming edge. All must pass on the evaluation window you claim (prefer OOS / walk-forward).",
  "require_all": true,
  "gates": {
    "profit_factor_min": 1.2,
    "max_drawdown_max_abs": 0.25,
    "sharpe_min": 0.5,
    "min_trades": 40,
    "expectancy_after_costs_min": 0.0
  },
  "vanity_not_sufficient": ["win_rate"],
  "preferred_windows": {
    "minimum_calendar_years": 3,
    "soft_research_ok": "2024-08 onward only for exploration",
    "hard_claim_requires": "start_date <= 2020-01-01 or walk-forward by quarter"
  },
  "ml_rules": {
    "primary_side": "rules_or_high_recall_primary",
    "secondary": "meta_label_filter_and_size",
    "forbid": ["random_kfold", "predict_next_close_as_primary", "tune_threshold_on_test"]
  }
}
